# ==========================
# ENVIRONMENT FILES (SECRETS)
# ==========================
# Never commit .env files with real secrets
.env
.env.local
.env.*.local
*.env
/frontend/.env
/frontend/.env.production

# ==========================
# PYTHON / FLASK BACKEND
# ==========================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg
venv/
env/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
htmlcov/
.pytest_cache/

# ==========================
# NODE / REACT FRONTEND
# ==========================
node_modules/
/frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/frontend/build/
/frontend/dist/
/frontend/.vite/

